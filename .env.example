# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host.example/neondb?sslmode=require

# Set to false for local Postgres without SSL
DATABASE_SSL=true

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_EXTRACT_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=6
OPENAI_TIMEOUT_MS=90000

# SimpleFIN sync window
SIMPLEFIN_SYNC_DAYS=90
SIMPLEFIN_SYNC_OVERLAP_DAYS=7

# 32-byte key as 64-char hex OR base64-encoded 32 bytes (recommended for production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIMPLEFIN_ENCRYPTION_KEY=

# Fallback when SIMPLEFIN_ENCRYPTION_KEY is unset (dev only)
SIMPLEFIN_ENCRYPTION_SECRET=change-me-in-production

PORT=3000
CORS_ORIGIN=*
